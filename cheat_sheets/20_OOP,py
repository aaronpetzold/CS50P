# ---------- 1. CLASS DEFINITION & INSTANTIATION ----------
# Definition: A class is a blueprint for creating objects.
# An object (instance) is a concrete realization of the class.

class MyClass:
    pass

# Create an instance:
obj = MyClass()


# ---------- 2. THE __init__ CONSTRUCTOR ----------
# Definition: Called automatically when an object is created.
# Use it to initialize instance variables.

class Person:
    def __init__(self, name, age):
        self.name = name      # instance variable
        self.age = age

p = Person("Alice", 30)


# ---------- 3. INSTANCE METHODS & THE self PARAMETER ----------
# Definition: Functions defined inside a class that operate on instances.
# self is the first parameter and refers to the current instance.

class Dog:
    def __init__(self, name):
        self.name = name

    def bark(self):
        return f"{self.name} says Woof!"

d = Dog("Rex")
print(d.bark())   # "Rex says Woof!"


# ---------- 4. INSTANCE VARIABLES ----------
# Definition: Variables that belong to each instance separately.
# Created using self.var = value inside __init__ or other methods.

class Car:
    def __init__(self, brand):
        self.brand = brand          # instance variable
        self.wheels = 4             # default value

c1 = Car("Toyota")
c2 = Car("Honda")
c1.brand = "Mazda"                  # changes only c1


# ---------- 5. CLASS VARIABLES (SHARED) ----------
# Definition: Variables defined directly in the class body.
# Shared by all instances of the class.

class Car:
    wheels = 4                      # class variable

    def __init__(self, brand):
        self.brand = brand          # instance variable

print(Car.wheels)    # 4
c = Car("BMW")
print(c.wheels)      # 4 (access via instance)
Car.wheels = 3       # changes for all instances


# ---------- 6. CLASS METHODS (@classmethod) ----------
# Definition: Method that belongs to the class, not to instances.
# First parameter is cls (the class itself).
# Useful for factory methods or operations on class-level data.

class Person:
    count = 0

    def __init__(self, name):
        self.name = name
        Person.count += 1

    @classmethod
    def from_string(cls, data):
        name, age = data.split(",")
        return cls(name, int(age))

    @classmethod
    def get_count(cls):
        return cls.count

p = Person.from_string("Bob,25")
print(Person.get_count())   # 1


# ---------- 7. STATIC METHODS (@staticmethod) ----------
# Definition: Regular function grouped inside a class.
# No self or cls parameter. Cannot access instance or class data.

class MathUtils:
    @staticmethod
    def add(a, b):
        return a + b

    @staticmethod
    def is_even(n):
        return n % 2 == 0

print(MathUtils.add(5, 3))      # 8
print(MathUtils.is_even(4))     # True


# ---------- 8. PROPERTIES: GETTER (@property) ----------
# Definition: Allows a method to be accessed like a variable.
# Use to compute values or control read access.

class Circle:
    def __init__(self, radius):
        self._radius = radius

    @property
    def radius(self):
        return self._radius

    @property
    def area(self):
        return 3.14159 * self._radius ** 2

c = Circle(5)
print(c.radius)   # 5 (looks like variable)
print(c.area)     # 78.53975 (computed)


# ---------- 9. PROPERTIES: SETTER (@attr.setter) ----------
# Definition: Controls assignment to an attribute.
# Enables validation or side effects.

class Person:
    def __init__(self, name):
        self.name = name        # calls setter

    @property
    def name(self):
        return self._name

    @name.setter
    def name(self, value):
        if not value:
            raise ValueError("Name cannot be empty")
        self._name = value

p = Person("Alice")
p.name = "Bob"      # OK
# p.name = ""       # raises ValueError


# ---------- 10. PROPERTIES: DELETER (@attr.deleter) ----------
# Definition: Controls what happens when you delete an attribute.

class Person:
    def __init__(self, name):
        self._name = name

    @property
    def name(self):
        return self._name

    @name.deleter
    def name(self):
        print("Deleting name")
        del self._name

p = Person("Alice")
del p.name          # prints "Deleting name"


# ---------- 11. MAGIC (DUNDER) METHODS ----------
# Special methods with double underscores.
# Define behavior for built-in operations.

class Book:
    def __init__(self, title, pages):
        self.title = title
        self.pages = pages

    # __str__: called by print() and str()
    def __str__(self):
        return f"'{self.title}'"

    # __repr__: called by repr(), used for debugging
    def __repr__(self):
        return f"Book('{self.title}', {self.pages})"

    # __len__: called by len()
    def __len__(self):
        return self.pages

    # __eq__: called by ==
    def __eq__(self, other):
        return self.title == other.title and self.pages == other.pages

    # __lt__: called by <
    def __lt__(self, other):
        return self.pages < other.pages

    # __add__: called by +
    def __add__(self, other):
        return self.pages + other.pages

    # __call__: makes object callable like a function
    def __call__(self, msg):
        return f"Book '{self.title}' says: {msg}"

b = Book("Python 101", 300)
print(b)            # __str__ → 'Python 101'
repr(b)             # __repr__ → Book('Python 101', 300)
len(b)              # __len__ → 300
b == Book("Python 101", 300)   # __eq__ → True
b < Book("Java", 400)          # __lt__ → True
b + Book("C++", 200)           # __add__ → 500
print(b("Hello"))   # __call__ → Book 'Python 101' says: Hello


# ---------- 12. INHERITANCE ----------
# Definition: A class can inherit attributes and methods from a parent class.

class Animal:
    def __init__(self, name):
        self.name = name

    def speak(self):
        return "Some sound"

class Dog(Animal):          # Dog inherits from Animal
    def speak(self):        # override method
        return "Woof!"

d = Dog("Rex")
print(d.name)     # inherited
print(d.speak())  # "Woof!"


# ---------- 13. THE super() FUNCTION ----------
# Definition: Calls a method from the parent class.
# Useful in __init__ and overridden methods.

class Parent:
    def __init__(self, a):
        self.a = a

class Child(Parent):
    def __init__(self, a, b):
        super().__init__(a)    # call Parent.__init__
        self.b = b


# ---------- 14. METHOD OVERRIDING ----------
# Definition: Redefining a method from the parent class in the child.

class Vehicle:
    def start(self):
        return "Starting vehicle"

class Motorcycle(Vehicle):
    def start(self):           # override
        return "Kickstarting motorcycle"

m = Motorcycle()
print(m.start())   # "Kickstarting motorcycle"


# ---------- 15. MULTIPLE INHERITANCE & MRO ----------
# Definition: A class can inherit from multiple parents.
# Method Resolution Order (MRO) determines which method is called.

class A:
    def method(self):
        return "A"

class B:
    def method(self):
        return "B"

class C(A, B):      # A comes before B
    pass

print(C().method()) # "A" (from A)

# View MRO:
print(C.__mro__)    # (<class 'C'>, <class 'A'>, <class 'B'>, ...)


# ---------- 16. PRIVATE & PROTECTED MEMBERS (name mangling) ----------
# Single underscore: "protected" (convention only)
# Double underscore: "private" (name mangling)

class MyClass:
    def __init__(self):
        self.public = "everyone"
        self._protected = "convention: do not touch"
        self.__private = "mangled to _MyClass__private"

obj = MyClass()
print(obj.public)            # OK
print(obj._protected)        # works but discouraged
# print(obj.__private)       # AttributeError
print(obj._MyClass__private) # works (but don't do it)


# ---------- 17. ABSTRACT CLASSES & METHODS (abc module) ----------
# Definition: Abstract classes cannot be instantiated.
# Subclasses must implement all abstract methods.

from abc import ABC, abstractmethod

class Shape(ABC):
    @abstractmethod
    def area(self):
        pass

    @abstractmethod
    def perimeter(self):
        pass

class Square(Shape):
    def __init__(self, side):
        self.side = side

    def area(self):
        return self.side ** 2

    def perimeter(self):
        return 4 * self.side

# s = Shape()           # TypeError (cannot instantiate)
sq = Square(5)          # OK
print(sq.area())        # 25


# ---------- 18. DATACLASSES (Python 3.7+) ----------
# Definition: Automatically generates __init__, __repr__, __eq__, etc.

from dataclasses import dataclass

@dataclass
class Point:
    x: int
    y: int

    def distance(self):
        return (self.x ** 2 + self.y ** 2) ** 0.5

p = Point(3, 4)
print(p)            # Point(x=3, y=4) (auto __repr__)
print(p.x)          # 3
print(p.distance()) # 5.0

# With default values:
@dataclass
class Person:
    name: str
    age: int = 0


# ---------- 19. QUICK REFERENCE TABLE ----------
# | Concept                  | Syntax / Example                              |
# |--------------------------|-----------------------------------------------|
# | Class definition         | `class MyClass:`                             |
# | Constructor              | `def __init__(self, arg):`                   |
# | Instance method          | `def method(self):`                          |
# | Instance variable        | `self.var = value`                           |
# | Class variable           | `class MyClass: var = value`                 |
# | Class method             | `@classmethod def method(cls):`              |
# | Static method            | `@staticmethod def method():`                |
# | Getter property          | `@property def attr(self): return self._attr`|
# | Setter property          | `@attr.setter def attr(self, val): self._attr = val` |
# | Deleter property         | `@attr.deleter def attr(self): del self._attr` |
# | __str__                  | `def __str__(self): return "..."`            |
# | __repr__                 | `def __repr__(self): return "..."`           |
# | __len__                  | `def __len__(self): return n`                |
# | __eq__                   | `def __eq__(self, other):`                   |
# | __lt__                   | `def __lt__(self, other):`                   |
# | __add__                  | `def __add__(self, other):`                  |
# | __call__                 | `def __call__(self, ...):`                   |
# | Inheritance              | `class Child(Parent):`                       |
# | Call parent method       | `super().method()`                           |
# | Private variable         | `self.__var` (mangles to _Class__var)        |
# | Abstract class           | `class MyClass(ABC):` with `@abstractmethod` |
# | Dataclass                | `@dataclass class Point: x: int; y: int`     |